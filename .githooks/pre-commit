#!/bin/sh
# Refuse to commit an internal seed.
#
# js/seed.js has two variants (see tools/gen_seed.py): `public` carries the demo
# owner, `internal` carries a real person's identity for local use. The repo is
# public, so only the public variant may ever be committed.
#
# This inspects the STAGED blob, not the working tree - the working tree is
# expected to hold the internal seed while developing locally.
#
# Enable once per clone:  git config core.hooksPath .githooks

staged_seed=$(git diff --cached --name-only --diff-filter=ACM | grep -x 'js/seed.js')
[ -z "$staged_seed" ] && exit 0

variant=$(git show :js/seed.js 2>/dev/null | head -c 200 | sed -n 's/.*window.SEED_VARIANT="\([a-z]*\)".*/\1/p')

if [ "$variant" = "internal" ]; then
  echo "pre-commit: BLOCKED - js/seed.js is the INTERNAL seed (real identity)." >&2
  echo "  The repo is public. Regenerate the public seed and stage it:" >&2
  echo "    python tools/gen_seed.py && git add js/seed.js" >&2
  echo "  Then restore your local seed after committing:" >&2
  echo "    python tools/gen_seed.py --internal" >&2
  exit 1
fi

if [ "$variant" != "public" ]; then
  echo "pre-commit: BLOCKED - js/seed.js has no recognised SEED_VARIANT marker." >&2
  echo "  Expected \"public\". Regenerate with: python tools/gen_seed.py" >&2
  exit 1
fi

exit 0
